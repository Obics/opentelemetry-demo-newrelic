# DO NOT PUSH CHANGES OF THIS FILE TO opentelemetry/opentelemetry-demo
# PLACE YOUR .env ENVIRONMENT VARIABLES OVERRIDES IN THIS FILE


# To use a real OpenAI API-compatible LLM,
# set the appropriate values for the target LLM
# Required permissions:
# [Models and Model capabilities]

#LLM_BASE_URL=https://api.openai.com/v1
#LLM_MODEL=gpt-4o-mini
#OPENAI_API_KEY=<replace with API key>

# *********
# New Relic
# *********
# Select corresponding OTLP endpoint depending where your account is.
NEW_RELIC_OTLP_ENDPOINT_US=https://otlp.nr-data.net:4317
NEW_RELIC_OTLP_ENDPOINT_EU=https://otlp.eu01.nr-data.net:4317
NEW_RELIC_OTLP_ENDPOINT=${NEW_RELIC_OTLP_ENDPOINT_US}

# License key is read from environment variable NEW_RELIC_LICENSE_KEY
# Do not define it here - Docker Compose will use the shell environment variable

# Helper for docker-compose.yaml
SRC_DIR=../../src/

# New Relic License Key (EU account)
NEW_RELIC_LICENSE_KEY=eu01xx754fbb0897138e4c3c8812652bFFFFNRAL